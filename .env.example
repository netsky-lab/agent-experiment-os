# For host-local development on machines where Docker publishes ports normally:
DATABASE_URL=postgresql://experiment_os:experiment_os@localhost:5432/experiment_os

# For commands running inside Docker Compose:
# DATABASE_URL=postgresql://experiment_os:experiment_os@postgres:5432/experiment_os

# Optional write protection for API endpoints that mutate experiments, reviews,
# briefs, or issue evidence. Leave empty for local development.
EXPERIMENT_OS_API_KEY=
NEXT_PUBLIC_EXPERIMENT_OS_API_KEY=

# Next.js dashboard API target. Use 8080 on machines where Docker port publishing
# works normally; use 8091 when running the dev-proxy fallback.
NEXT_PUBLIC_EXPERIMENT_OS_API_URL=http://127.0.0.1:8080
